# Board: CrowPanel Advanced 10.1" ESP32-P4 (1024x600 MIPI DSI)
CONFIG_KERN_BOARD_CROWPANEL_101=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y

# SD card: GPIO matrix pins and 1-bit mode (CLK=43, CMD=44, D0=39)
CONFIG_SD_CLK_GPIO=43
CONFIG_SD_CMD_GPIO=44
CONFIG_SD_D0_GPIO=39
CONFIG_SD_BUS_WIDTH=1
CONFIG_SD_INTERNAL_PULLUP=y
